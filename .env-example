# iQua credentials for test_websocket.py
IQUA_USERNAME=user-name-here
IQUA_PASSWORD=password-here

# Use only one of the following two lines to specify the device serial number
IQUA_DEVICE_SERIAL=device-serial-here
IQUA_PRODUCT_SERIAL=product-serial-here


# Optional: override the default API domain (leave blank to use api.myiquaapp.com)
# The script derives https://{domain}/v1 and wss://{domain} from this value.
# Example: IQUA_API_DOMAIN=api.iqua2.com
IQUA_API_DOMAIN=
